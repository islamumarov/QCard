# Copy to .env.local and fill in.

# Which LLM provider drives the interview: "anthropic" (default) or "gemini".
QCARD_PROVIDER=anthropic

# --- Anthropic (Claude) — https://console.anthropic.com/ ---
ANTHROPIC_API_KEY=sk-ant-...
# QCARD_ANTHROPIC_MODEL=claude-opus-4-8

# --- Google Gemini — https://aistudio.google.com/apikey ---
GEMINI_API_KEY=
# QCARD_GEMINI_MODEL=gemini-2.5-flash   # or gemini-2.5-pro

# If no key for the selected provider is set, the app runs with built-in
# fallback follow-ups/feedback so it still works end-to-end.

# --- Google sign-in (optional) — https://console.cloud.google.com/apis/credentials ---
# Create an OAuth 2.0 Client ID (Web) with redirect URI
#   http://localhost:3000/api/auth/callback/google
# Leave these blank to disable sign-in entirely (the app runs without auth).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Session-encryption secret (required only when the two values above are set).
# Generate with: npx auth secret   — or — openssl rand -base64 32
AUTH_SECRET=

# --- App options ---
# QCARD_DB_PATH=./data/qcard.db
# Number of main questions per interview session
# QCARD_MAIN_QUESTIONS=5
# Max follow-ups the interviewer may ask per main question
# QCARD_MAX_FOLLOWUPS=2
